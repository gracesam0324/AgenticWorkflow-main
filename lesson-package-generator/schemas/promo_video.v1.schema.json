{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromoVideoV1",
  "type": "object",
  "required": ["format", "narration", "subtitles", "storyboard"],
  "properties": {
    "format": { "const": "promo-video.v1" },
    "storyboard": {
      "type": "object",
      "required": ["cuts"],
      "properties": {
        "cuts": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "required": [
              "id",
              "duration_seconds",
              "scene_description",
              "video_prompt",
              "subtitle"
            ]
          }
        }
      }
    }
  }
}
