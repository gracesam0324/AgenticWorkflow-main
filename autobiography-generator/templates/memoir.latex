% memoir.latex — Custom LaTeX template for autobiography PDF generation
% Uses the memoir document class for professional book typesetting
% Supports: A5 (screen), 6x9 US Trade (KDP print), 5x8 (compact)
% Engine: XeLaTeX (required for fontspec + xeCJK)
% Invoked by: pandoc --template=templates/memoir.latex --pdf-engine=xelatex

\documentclass[12pt, $if(papersize)$$papersize$$else$a5paper$endif$, $if(twoside)$twoside$else$oneside$endif$, openany]{memoir}

%%% ============================================================
%%% FONTS
%%% ============================================================
\usepackage{fontspec}

% Primary font: EB Garamond (classic memoir feel)
% Fallback: TeX Gyre Termes (always available in TeX Live)
\IfFontExistsTF{EB Garamond}{%
  \setmainfont{EB Garamond}[
    BoldFont       = {EB Garamond Bold},
    ItalicFont     = {EB Garamond Italic},
    BoldItalicFont = {EB Garamond Bold Italic},
    Numbers        = OldStyle,
    Ligatures      = TeX,
  ]
}{%
  \setmainfont{TeX Gyre Termes}[
    BoldFont       = {TeX Gyre Termes Bold},
    ItalicFont     = {TeX Gyre Termes Italic},
    BoldItalicFont = {TeX Gyre Termes Bold Italic},
  ]
}

\setsansfont{TeX Gyre Heros}
\setmonofont{TeX Gyre Cursor}

%%% ============================================================
%%% CJK (Korean) FONT SUPPORT
%%% ============================================================
$if(cjk)$
\usepackage{xeCJK}
\IfFontExistsTF{Noto Serif CJK KR}{%
  \setCJKmainfont{Noto Serif CJK KR}[
    BoldFont   = Noto Serif CJK KR Bold,
    ItalicFont = Noto Serif CJK KR,
    ItalicFeatures = {FakeSlant=0.2},
  ]
}{%
  \IfFontExistsTF{NanumMyeongjo}{%
    \setCJKmainfont{NanumMyeongjo}
  }{%
    % No CJK font found — will produce warnings on CJK text
  }
}
\IfFontExistsTF{Noto Sans CJK KR}{%
  \setCJKsansfont{Noto Sans CJK KR}
}{}
\IfFontExistsTF{Noto Sans Mono CJK KR}{%
  \setCJKmonofont{Noto Sans Mono CJK KR}
}{}
$endif$

%%% ============================================================
%%% LANGUAGE
%%% ============================================================
\usepackage{polyglossia}
\setmainlanguage{english}
$if(lang)$
\setotherlanguage{$lang$}
$endif$

%%% ============================================================
%%% PAGE LAYOUT — Conditional by paper size
%%% ============================================================

% --- 6x9 US Trade (Amazon KDP / IngramSpark) ---
$if(papersize-trade)$
\setstocksize{9in}{6in}
\settrimmedsize{9in}{6in}{*}
% Inner margin scales with page count; 0.75in is safe for up to ~300 pages
\setlrmarginsandblock{$if(inner-margin)$$inner-margin$$else$0.75in$endif$}{0.5in}{*}
\setulmarginsandblock{0.75in}{0.75in}{*}
$endif$

% --- 6x9 with bleed (for KDP bleed-enabled books) ---
$if(papersize-trade-bleed)$
\setstocksize{9.25in}{6.125in}
\settrimmedsize{9in}{6in}{*}
\settrims{0.125in}{0.125in}
\setlrmarginsandblock{$if(inner-margin)$$inner-margin$$else$0.875in$endif$}{0.625in}{*}
\setulmarginsandblock{0.875in}{0.875in}{*}
$endif$

% --- 5x8 Compact ---
$if(papersize-compact)$
\setstocksize{8in}{5in}
\settrimmedsize{8in}{5in}{*}
\setlrmarginsandblock{0.7in}{0.5in}{*}
\setulmarginsandblock{0.6in}{0.8in}{*}
$endif$

% --- A5 (default, for screen reading) ---
$if(papersize-a5)$
\setlrmarginsandblock{2.5cm}{2cm}{*}
\setulmarginsandblock{2.5cm}{2.5cm}{*}
$endif$

% Default: A5 if no paper size variable set
$if(papersize-trade)$$else$$if(papersize-trade-bleed)$$else$$if(papersize-compact)$$else$$if(papersize-a5)$$else$
\setlrmarginsandblock{2.5cm}{2cm}{*}
\setulmarginsandblock{2.5cm}{2.5cm}{*}
$endif$$endif$$endif$$endif$

\checkandfixthelayout

%%% ============================================================
%%% LINE SPACING
%%% ============================================================
$if(line-stretch)$
\usepackage{setspace}
\setstretch{$line-stretch$}
$endif$

%%% ============================================================
%%% HEADERS AND FOOTERS
%%% ============================================================
\makepagestyle{autobiography}
\makeevenhead{autobiography}{\small\itshape\leftmark}{}{}
\makeoddhead{autobiography}{}{}{\small\itshape\rightmark}
\makeevenfoot{autobiography}{}{\thepage}{}
\makeoddfoot{autobiography}{}{\thepage}{}
\pagestyle{autobiography}

% Plain style for chapter openings
\makepagestyle{plain}
\makeevenhead{plain}{}{}{}
\makeoddhead{plain}{}{}{}
\makeevenfoot{plain}{}{\thepage}{}
\makeoddfoot{plain}{}{\thepage}{}

%%% ============================================================
%%% CHAPTER STYLE
%%% ============================================================
\makechapterstyle{autobiographychapter}{%
  \chapterstyle{default}
  \renewcommand*{\chapnumfont}{\normalfont\Large\scshape}
  \renewcommand*{\chaptitlefont}{\normalfont\Huge\itshape}
  \renewcommand*{\printchaptername}{}
  \renewcommand*{\chapternamenum}{}
  \renewcommand*{\printchapternum}{%
    \centering
    \chapnumfont Chapter \thechapter
    \par\nobreak\vskip 10pt
  }
  \renewcommand*{\printchaptertitle}[1]{%
    \centering
    \chaptitlefont ##1
    \par\nobreak\vskip 30pt
  }
  \renewcommand*{\afterchapternum}{}
}
\chapterstyle{autobiographychapter}

%%% ============================================================
%%% SECTION STYLES
%%% ============================================================
\setsecheadstyle{\large\bfseries\memRTLraggedright}
\setsubsecheadstyle{\normalsize\bfseries\memRTLraggedright}

%%% ============================================================
%%% PARAGRAPH STYLE
%%% ============================================================
\setlength{\parindent}{1.5em}
\setlength{\parskip}{0pt plus 1pt}
\abnormalparskip{0.5\baselineskip}

%%% ============================================================
%%% EPIGRAPH SUPPORT (memoir built-in)
%%% ============================================================
\setlength{\epigraphwidth}{0.7\textwidth}
\setlength{\epigraphrule}{0pt}
\renewcommand{\epigraphflush}{center}
\renewcommand{\sourceflush}{center}

%%% ============================================================
%%% BLOCK QUOTE STYLE (for letters, internal monologue)
%%% ============================================================
\renewenvironment{quote}
  {\list{}{\rightmargin=1em\leftmargin=2em\itshape}%
   \item\relax}
  {\endlist}

%%% ============================================================
%%% SCENE BREAK MARKERS
%%% ============================================================

% Standard scene break — horizontal rule
\newcommand{\scenebreak}{%
  \par\vspace{1.5\baselineskip}
  \noindent\hfil\rule{0.3\textwidth}{0.4pt}\hfil
  \par\vspace{1.5\baselineskip}
  \noindent
}

% Three-asterisk scene break
\newcommand{\scenebreakstars}{%
  \par\vspace{1.5\baselineskip}
  \noindent\hfil{*\quad*\quad*}\hfil
  \par\vspace{1.5\baselineskip}
  \noindent
}

% Three-dot scene break
\newcommand{\scenebreakdots}{%
  \par\vspace{1.5\baselineskip}
  \noindent\hfil{$\bullet$\quad$\bullet$\quad$\bullet$}\hfil
  \par\vspace{1.5\baselineskip}
  \noindent
}

% Blank-space scene break (subtle)
\newcommand{\scenebreakblank}{%
  \par\vspace{3\baselineskip}
  \noindent
}

%%% ============================================================
%%% DROP CAPS (lettrine)
%%% ============================================================
\usepackage{lettrine}
\renewcommand{\LettrineFontHook}{\color{chaptercolor}}
\setcounter{DefaultLines}{3}
\renewcommand{\DefaultLoversize}{0.1}
\renewcommand{\DefaultLhang}{0.05}

%%% ============================================================
%%% HYPERLINKS (invisible in print, functional in PDF)
%%% ============================================================
\usepackage[hidelinks, pdfusetitle, bookmarksnumbered]{hyperref}
$if(title)$
\hypersetup{
  pdftitle={$title$},
  $if(author)$pdfauthor={$for(author)$$author$$sep$, $endfor$},$endif$
  $if(subject)$pdfsubject={$for(subject)$$subject$$sep$; $endfor$},$endif$
  pdfcreator={Pandoc + XeLaTeX + memoir},
}
$endif$

%%% ============================================================
%%% IMAGES AND FIGURES
%%% ============================================================
\usepackage{graphicx}
\usepackage{float}  % for [H] placement specifier
$if(graphics-path)$
\graphicspath{{$graphics-path$}}
$endif$

% Tighten up figure spacing
\setlength{\textfloatsep}{1.5\baselineskip plus 0.2\baselineskip minus 0.5\baselineskip}
\setlength{\floatsep}{\baselineskip plus 0.2\baselineskip minus 0.5\baselineskip}

% Caption styling for photos
\captionnamefont{\small\itshape}
\captiontitlefont{\small}
\captiondelim{ --- }
\captionstyle{\centering}

%%% --- Photo placement macros ---

% Full-page photo
\newcommand{\photopage}[2]{%  #1=image path, #2=caption
  \clearpage
  \thispagestyle{empty}
  \vspace*{\fill}
  \begin{center}
    \includegraphics[width=0.85\textwidth,keepaspectratio]{#1}
    \par\vspace{0.5cm}
    {\small\itshape #2}
  \end{center}
  \vspace*{\fill}
  \clearpage
}

% Inline photo (within text flow)
\newcommand{\inlinephoto}[3][0.6\textwidth]{%  [width], path, caption
  \begin{figure}[htbp]
    \centering
    \includegraphics[width=#1,keepaspectratio]{#2}
    \caption{#3}
  \end{figure}
}

% Two photos side by side
\newcommand{\photospread}[4]{%  img1, cap1, img2, cap2
  \begin{figure}[htbp]
    \centering
    \begin{minipage}[t]{0.48\textwidth}
      \centering
      \includegraphics[width=\textwidth,keepaspectratio]{#1}
      \par\vspace{0.3cm}
      {\small\itshape #2}
    \end{minipage}
    \hfill
    \begin{minipage}[t]{0.48\textwidth}
      \centering
      \includegraphics[width=\textwidth,keepaspectratio]{#3}
      \par\vspace{0.3cm}
      {\small\itshape #4}
    \end{minipage}
  \end{figure}
}

%%% ============================================================
%%% TABLES
%%% ============================================================
\usepackage{longtable}
\usepackage{booktabs}
\usepackage{array}

%%% ============================================================
%%% COLORS
%%% ============================================================
\usepackage{xcolor}
\definecolor{chaptercolor}{gray}{0.3}

%%% ============================================================
%%% MICRO-TYPOGRAPHY (subtle quality improvement)
%%% ============================================================
$if(microtypography)$
\usepackage{microtype}
$endif$

%%% ============================================================
%%% PANDOC-SPECIFIC FIXES
%%% ============================================================

% Pandoc tight lists
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

% Pandoc CSL references
$if(csl-refs)$
\newlength{\cslhangindent}
\setlength{\cslhangindent}{1.5em}
\newlength{\csllabelwidth}
\setlength{\csllabelwidth}{3em}
\newenvironment{CSLReferences}[2]%
  {\begin{list}{}{%
   \setlength{\itemindent}{0pt}
   \setlength{\leftmargin}{0pt}
   \setlength{\parsep}{0pt}
   \ifnum##1>0
    \setlength{\leftmargin}{\cslhangindent}
    \setlength{\itemindent}{-\cslhangindent}
   \fi}
  }
  {\end{list}}
\newcommand{\CSLBlock}[1]{##1\hfill\break}
\newcommand{\CSLLeftMargin}[1]{\parbox[t]{\csllabelwidth}{##1}}
\newcommand{\CSLRightInline}[1]{\parbox[t]{\linewidth - \csllabelwidth}{##1}\break}
\newcommand{\CSLIndent}[1]{\hspace{\cslhangindent}##1}
$endif$

%%% ============================================================
%%% METADATA
%%% ============================================================
$if(title)$
\title{$title$}
$endif$
$if(author)$
\author{$for(author)$$author$$sep$ \and $endfor$}
$endif$
$if(date)$
\date{$date$}
$endif$

%%% ============================================================
%%% HEADER INCLUDES (user-injected LaTeX)
%%% ============================================================
$for(header-includes)$
$header-includes$
$endfor$

%%% ============================================================
%%% DOCUMENT
%%% ============================================================

\begin{document}

%%% --- Front Matter ---
\frontmatter

% Half title page
\thispagestyle{empty}
\vspace*{3cm}
\begin{center}
{\Large\itshape $if(title)$$title$$endif$}
\end{center}
\cleardoublepage

% Full title page
\thispagestyle{empty}
\vspace*{2cm}
\begin{center}
{\Huge\bfseries $if(title)$$title$$endif$}

\vspace{1cm}
$if(subtitle)$
{\Large\itshape $subtitle$}

\vspace{1cm}
$endif$

$if(author)$
{\large $for(author)$$author$$sep$ \\ $endfor$}
$endif$

\vfill

$if(publisher)$
{\normalsize $publisher$}

$endif$
{\small $if(date)$$date$$endif$}
\end{center}
\cleardoublepage

% Copyright page
\thispagestyle{empty}
\vspace*{\fill}
\begin{flushleft}
\small
$if(title)$\textit{$title$}$endif$

$if(author)$
Copyright \copyright\ $if(date)$$date$$endif$ by $for(author)$$author$$sep$, $endfor$

All rights reserved. No part of this publication may be reproduced,
distributed, or transmitted in any form or by any means without the
prior written permission of the author.
$endif$

$if(isbn)$

ISBN: $isbn$
$endif$

$if(edition)$

$edition$
$endif$

$if(copyright-note)$
\vspace{0.5cm}
$copyright-note$
$endif$

\vspace{1cm}
$if(colophon-short)$
{\footnotesize $colophon-short$}
$else$
{\footnotesize Typeset with \XeLaTeX\ using the memoir document class.}
$endif$
\end{flushleft}
\cleardoublepage

% Dedication
$if(dedication)$
\thispagestyle{empty}
\vspace*{5cm}
\begin{center}
\itshape
$dedication$
\end{center}
\cleardoublepage
$endif$

% Epigraph (book-level)
$if(epigraph)$
\thispagestyle{empty}
\vspace*{4cm}
\epigraph{$epigraph$}{$if(epigraph-author)$--- $epigraph-author$$endif$}
\cleardoublepage
$endif$

% Table of Contents
$if(toc)$
\tableofcontents*
\cleardoublepage
$endif$

% List of Illustrations
$if(loi)$
\listoffigures*
\cleardoublepage
$endif$

% Foreword (by someone other than the author)
$if(foreword)$
\chapter*{Foreword}
\addcontentsline{toc}{chapter}{Foreword}
$foreword$
\cleardoublepage
$endif$

% Preface / Author's Note
$if(preface)$
\chapter*{Preface}
\addcontentsline{toc}{chapter}{Preface}
$preface$
\cleardoublepage
$endif$

%%% --- Main Matter ---
\mainmatter

$body$

%%% --- Back Matter ---
\backmatter

$if(acknowledgments)$
\chapter*{Acknowledgments}
\addcontentsline{toc}{chapter}{Acknowledgments}
$acknowledgments$
$endif$

$if(afterword)$
\chapter*{Afterword}
\addcontentsline{toc}{chapter}{Afterword}
$afterword$
$endif$

$if(timeline)$
\chapter*{Timeline}
\addcontentsline{toc}{chapter}{Timeline}
$timeline$
$endif$

$if(bibliography-section)$
\chapter*{Bibliography}
\addcontentsline{toc}{chapter}{Bibliography}
$bibliography-section$
$endif$

$if(about-author)$
\chapter*{About the Author}
\addcontentsline{toc}{chapter}{About the Author}
$about-author$
$endif$

$if(colophon)$
\cleardoublepage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
\small\itshape
$colophon$
\end{center}
$endif$

\end{document}
