{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chapter_draft.schema.json",
  "title": "Chapter Draft",
  "description": "Schema for chapter draft metadata and structure. The actual prose lives in the markdown body; this schema governs the structured header that accompanies each chapter draft for validation and tracking.",
  "type": "object",
  "required": ["meta", "structure", "source_traceability", "voice_metrics"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["chapter_number", "title", "draft_version", "word_count", "created_date", "author_agent"],
      "properties": {
        "chapter_number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "draft_version": {
          "type": "integer",
          "minimum": 1,
          "description": "Incremented on each revision cycle"
        },
        "word_count": {
          "type": "integer",
          "minimum": 500,
          "description": "Total word count of the prose body"
        },
        "target_word_count": { "type": "integer", "minimum": 1000 },
        "word_count_deviation_pct": {
          "type": "number",
          "description": "Percentage deviation from target: (actual - target) / target * 100"
        },
        "created_date": { "type": "string", "format": "date" },
        "last_revised": { "type": "string", "format": "date" },
        "author_agent": {
          "type": "string",
          "description": "The agent that produced this draft, e.g. '@chapter-writer'"
        },
        "reviewer_agent": {
          "type": "string",
          "description": "The agent that reviewed this draft, e.g. '@reviewer'"
        },
        "status": {
          "type": "string",
          "enum": ["first-draft", "revised", "reviewed", "approved", "final"],
          "description": "Current status in the writing pipeline"
        }
      }
    },
    "structure": {
      "type": "object",
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["section_id", "heading", "word_count", "content_type"],
            "properties": {
              "section_id": {
                "type": "string",
                "pattern": "^CH[0-9]{2}-S[0-9]{2}$",
                "description": "Section identifier, e.g. CH03-S01"
              },
              "heading": { "type": "string" },
              "word_count": { "type": "integer", "minimum": 0 },
              "content_type": {
                "type": "string",
                "enum": ["scene", "reflection", "exposition", "dialogue", "transition", "montage"],
                "description": "Primary content mode of this section"
              },
              "time_period": { "type": "string" },
              "characters_present": {
                "type": "array",
                "items": { "type": "string", "pattern": "^CHAR-[0-9]{3}$" }
              },
              "place": { "type": "string", "pattern": "^PLC-[0-9]{3}$" },
              "events_covered": {
                "type": "array",
                "items": { "type": "string", "pattern": "^EVT-[0-9]{4}$" }
              },
              "themes_active": {
                "type": "array",
                "items": { "type": "string", "pattern": "^THM-[0-9]{2}$" }
              }
            }
          }
        },
        "opening_line": {
          "type": "string",
          "description": "Exact first sentence of the chapter"
        },
        "closing_line": {
          "type": "string",
          "description": "Exact last sentence of the chapter"
        },
        "chapter_arc": {
          "type": "string",
          "description": "One-sentence summary of the emotional/narrative arc"
        }
      }
    },
    "source_traceability": {
      "type": "object",
      "required": ["interviews_used", "story_bible_version"],
      "properties": {
        "interviews_used": {
          "type": "array",
          "items": { "type": "string", "pattern": "^INT-[0-9]{3}$" },
          "minItems": 1,
          "description": "Which interview transcripts were used as source material"
        },
        "segments_referenced": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["interview", "segment"],
            "properties": {
              "interview": { "type": "string", "pattern": "^INT-[0-9]{3}$" },
              "segment": { "type": "string", "pattern": "^SEG-[0-9]{3}$" },
              "used_for": { "type": "string" }
            }
          },
          "description": "Specific interview segments that informed this chapter"
        },
        "story_bible_version": {
          "type": "integer",
          "minimum": 1,
          "description": "Version of the story bible used when writing this chapter"
        },
        "direct_quotes_used": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of direct quotes from interviews included verbatim"
        },
        "fabricated_scenes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["section_id", "justification"],
            "properties": {
              "section_id": { "type": "string", "pattern": "^CH[0-9]{2}-S[0-9]{2}$" },
              "justification": {
                "type": "string",
                "description": "Why this scene was created without direct interview source"
              }
            }
          },
          "description": "Scenes not directly sourced from interviews — must be justified"
        }
      }
    },
    "voice_metrics": {
      "type": "object",
      "required": ["avg_sentence_length", "dialogue_ratio", "show_vs_tell_ratio"],
      "properties": {
        "avg_sentence_length": {
          "type": "number",
          "minimum": 5,
          "maximum": 50,
          "description": "Average words per sentence"
        },
        "sentence_length_std": {
          "type": "number",
          "description": "Standard deviation of sentence lengths — higher = more varied"
        },
        "dialogue_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of text that is dialogue (0.0 to 1.0)"
        },
        "show_vs_tell_ratio": {
          "type": "number",
          "minimum": 0,
          "description": "Ratio of concrete/sensory language to abstract/telling language"
        },
        "unique_word_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Type-token ratio — lexical diversity measure"
        },
        "passive_voice_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of sentences using passive voice"
        },
        "adverb_density": {
          "type": "number",
          "minimum": 0,
          "description": "Adverbs per 1000 words"
        },
        "forbidden_word_violations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["word", "count", "locations"],
            "properties": {
              "word": { "type": "string" },
              "count": { "type": "integer" },
              "locations": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "continuity_check": {
      "type": "object",
      "description": "Cross-chapter consistency data for validation",
      "properties": {
        "characters_introduced": {
          "type": "array",
          "items": { "type": "string", "pattern": "^CHAR-[0-9]{3}$" },
          "description": "Characters appearing for the first time in this chapter"
        },
        "characters_referenced": {
          "type": "array",
          "items": { "type": "string", "pattern": "^CHAR-[0-9]{3}$" },
          "description": "Characters mentioned who appeared in earlier chapters"
        },
        "timeline_start": { "type": "string" },
        "timeline_end": { "type": "string" },
        "unresolved_threads": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Narrative threads opened but not yet closed"
        },
        "resolved_threads": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Threads from previous chapters resolved here"
        }
      }
    }
  }
}
