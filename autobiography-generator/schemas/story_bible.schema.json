{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "story_bible.schema.json",
  "title": "Story Bible",
  "description": "Master reference document for the autobiography. Contains all canonical facts about characters, places, timeline, themes, and narrative structure. This is the SOT for narrative consistency.",
  "type": "object",
  "required": ["meta", "subject", "characters", "timeline", "places", "themes", "chapter_plan"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "subtitle", "created_date", "last_updated", "version"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" },
        "created_date": { "type": "string", "format": "date" },
        "last_updated": { "type": "string", "format": "date" },
        "version": { "type": "integer", "minimum": 1 },
        "target_word_count": {
          "type": "integer",
          "minimum": 10000,
          "maximum": 500000,
          "description": "Target total word count for the complete book"
        },
        "target_audience": { "type": "string" },
        "narrative_voice": {
          "type": "string",
          "enum": ["first-person-past", "first-person-present", "third-person-limited", "third-person-omniscient"],
          "description": "The narrative perspective and tense"
        },
        "tone_profile": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "avoid": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tones to explicitly avoid, e.g. ['preachy', 'self-pitying']"
            }
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "required": ["full_name", "birth_year", "core_identity"],
      "properties": {
        "full_name": { "type": "string" },
        "birth_year": { "type": "integer" },
        "birth_place": { "type": "string" },
        "core_identity": {
          "type": "string",
          "minLength": 50,
          "description": "2-3 sentence encapsulation of who this person is at their core"
        },
        "defining_traits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["trait", "evidence"],
            "properties": {
              "trait": { "type": "string" },
              "evidence": { "type": "string", "description": "Specific example or source interview" }
            }
          },
          "minItems": 3,
          "maxItems": 10
        },
        "speech_patterns": {
          "type": "object",
          "properties": {
            "favorite_expressions": { "type": "array", "items": { "type": "string" } },
            "vocabulary_level": { "type": "string", "enum": ["colloquial", "educated", "academic", "mixed"] },
            "humor_style": { "type": "string" },
            "sample_sentences": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Actual sentences from interviews that capture their voice"
            }
          }
        }
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "relationship", "importance", "first_appearance"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CHAR-[0-9]{3}$",
            "description": "Unique character identifier"
          },
          "name": { "type": "string" },
          "aliases": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Other names/nicknames used in interviews"
          },
          "relationship": { "type": "string" },
          "importance": {
            "type": "string",
            "enum": ["primary", "secondary", "mentioned"],
            "description": "primary = appears in multiple chapters; secondary = appears in 1-2; mentioned = referenced but not developed"
          },
          "birth_year": { "type": "integer" },
          "death_year": { "type": "integer" },
          "physical_description": { "type": "string" },
          "personality_summary": { "type": "string" },
          "key_interactions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["description", "chapter"],
              "properties": {
                "description": { "type": "string" },
                "chapter": { "type": "integer" },
                "source_interview": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
              }
            }
          },
          "first_appearance": {
            "type": "object",
            "required": ["chapter"],
            "properties": {
              "chapter": { "type": "integer", "minimum": 1 },
              "context": { "type": "string" }
            }
          },
          "last_appearance": {
            "type": "object",
            "properties": {
              "chapter": { "type": "integer" },
              "context": { "type": "string" }
            }
          },
          "arc": {
            "type": "string",
            "description": "Brief description of how the relationship evolves across the narrative"
          }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date_display", "sort_key", "event", "significance"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^EVT-[0-9]{4}$"
          },
          "date_display": {
            "type": "string",
            "description": "Human-readable date, e.g. 'Spring 1985' or 'March 12, 1992'"
          },
          "sort_key": {
            "type": "string",
            "pattern": "^[0-9]{4}(-[0-9]{2})?(-[0-9]{2})?$",
            "description": "ISO-sortable key: YYYY or YYYY-MM or YYYY-MM-DD"
          },
          "event": { "type": "string" },
          "significance": {
            "type": "string",
            "enum": ["turning-point", "milestone", "background", "anecdote"]
          },
          "characters_involved": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CHAR-[0-9]{3}$" }
          },
          "place": { "type": "string" },
          "chapter": { "type": "integer", "minimum": 1 },
          "source_interviews": {
            "type": "array",
            "items": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
          },
          "narrative_note": {
            "type": "string",
            "description": "How this event should be handled narratively"
          }
        }
      }
    },
    "places": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "significance"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^PLC-[0-9]{3}$"
          },
          "name": { "type": "string" },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "description": { "type": "string" },
          "years_relevant": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "significance": {
            "type": "string",
            "enum": ["home", "workplace", "school", "travel", "landmark", "other"]
          },
          "sensory_details": {
            "type": "object",
            "properties": {
              "sights": { "type": "array", "items": { "type": "string" } },
              "sounds": { "type": "array", "items": { "type": "string" } },
              "smells": { "type": "array", "items": { "type": "string" } },
              "textures": { "type": "array", "items": { "type": "string" } }
            },
            "description": "Sensory details from interviews to ground scene-setting"
          },
          "chapters_featured": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      }
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "chapters"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^THM-[0-9]{2}$"
          },
          "name": { "type": "string" },
          "description": {
            "type": "string",
            "minLength": 30,
            "description": "What this theme means in the context of the subject's life"
          },
          "chapters": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 1,
            "description": "Chapters where this theme appears"
          },
          "evolution": {
            "type": "string",
            "description": "How the theme develops across the narrative arc"
          },
          "source_interviews": {
            "type": "array",
            "items": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
          }
        }
      },
      "minItems": 3
    },
    "chapter_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter_number", "title", "time_period", "summary", "target_word_count"],
        "properties": {
          "chapter_number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "time_period": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" }
            }
          },
          "summary": {
            "type": "string",
            "minLength": 100,
            "description": "Detailed chapter synopsis (not just a one-liner)"
          },
          "target_word_count": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 30000
          },
          "key_events": {
            "type": "array",
            "items": { "type": "string", "pattern": "^EVT-[0-9]{4}$" }
          },
          "characters_featured": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CHAR-[0-9]{3}$" }
          },
          "places_featured": {
            "type": "array",
            "items": { "type": "string", "pattern": "^PLC-[0-9]{3}$" }
          },
          "themes_active": {
            "type": "array",
            "items": { "type": "string", "pattern": "^THM-[0-9]{2}$" }
          },
          "source_interviews": {
            "type": "array",
            "items": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
          },
          "opening_hook": {
            "type": "string",
            "description": "Suggested opening line or scene to hook the reader"
          },
          "closing_bridge": {
            "type": "string",
            "description": "How this chapter transitions to the next"
          },
          "narrative_technique": {
            "type": "string",
            "description": "Primary storytelling approach, e.g. 'flashback', 'chronological', 'vignette-collage'"
          }
        }
      },
      "minItems": 3
    },
    "voice_guide": {
      "type": "object",
      "properties": {
        "sentence_length": {
          "type": "object",
          "properties": {
            "average_words": { "type": "integer", "minimum": 8, "maximum": 30 },
            "max_words": { "type": "integer", "maximum": 60 },
            "variation_note": { "type": "string" }
          }
        },
        "paragraph_length": {
          "type": "object",
          "properties": {
            "average_sentences": { "type": "integer", "minimum": 2, "maximum": 10 },
            "max_sentences": { "type": "integer", "maximum": 15 }
          }
        },
        "forbidden_words": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Words the subject would never use or that break voice"
        },
        "preferred_constructions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Syntactic patterns that match the subject's voice"
        },
        "show_dont_tell_requirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Emotions/states that must be shown through action, never stated directly"
        }
      }
    },
    "fact_registry": {
      "type": "object",
      "description": "Hard facts that must never be contradicted across chapters",
      "properties": {
        "dates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["fact", "value", "source"],
            "properties": {
              "fact": { "type": "string" },
              "value": { "type": "string" },
              "source": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
            }
          }
        },
        "names": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["canonical", "source"],
            "properties": {
              "canonical": { "type": "string" },
              "variants": { "type": "array", "items": { "type": "string" } },
              "source": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
            }
          }
        },
        "places": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["canonical", "source"],
            "properties": {
              "canonical": { "type": "string" },
              "variants": { "type": "array", "items": { "type": "string" } },
              "source": { "type": "string", "pattern": "^INT-[0-9]{3}$" }
            }
          }
        }
      }
    }
  }
}
